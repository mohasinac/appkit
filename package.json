{
  "name": "@mohasinac/appkit",
  "version": "2.3.0",
  "description": "All-in-one application toolkit — consolidates all @mohasinac/* packages into a single, well-structured package with sub-path exports",
  "author": "Mohasin AC",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mohasinac/appkit.git"
  },
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "browser": "./dist/client.js",
      "default": "./dist/server.js"
    },
    "./server": "./dist/server.js",
    "./client": "./dist/client.js",
    "./*": "./dist/*/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/generate-index.mjs && node scripts/generate-server.mjs && node scripts/generate-client.mjs && tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "generate": "node scripts/generate-index.mjs && node scripts/generate-server.mjs && node scripts/generate-client.mjs",
    "watch": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@mohasinac/sievejs": "^1.0.0",
    "client-only": "^0.0.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "firebase-admin": ">=12.0.0",
    "next": ">=14",
    "next-intl": ">=3",
    "razorpay": ">=2.9.0",
    "react": ">=18",
    "react-dom": ">=18",
    "recharts": "^3.8.1",
    "resend": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "firebase-admin": {
      "optional": true
    },
    "resend": {
      "optional": true
    },
    "razorpay": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "eslint": "^9.37.0",
    "firebase": "^11.6.0",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^1.7.0",
    "next": "^15.0.0",
    "next-intl": "^4.9.1",
    "razorpay": "^2.9.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.10.0",
    "typescript": "^5.9.3"
  }
}
