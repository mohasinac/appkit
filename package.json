{
  "name": "@mohasinac/appkit",
  "version": "2.1.3",
  "description": "All-in-one application toolkit — consolidates all @mohasinac/* packages into a single, well-structured package with sub-path exports",
  "author": "Mohasin AC",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mohasinac/appkit.git"
  },
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./contracts": {
      "types": "./src/contracts/index.ts",
      "default": "./src/contracts/index.ts"
    },
    "./core": {
      "types": "./src/core/index.ts",
      "default": "./src/core/index.ts"
    },
    "./core/newsletter.repository": {
      "types": "./src/core/newsletter.repository.ts",
      "default": "./src/core/newsletter.repository.ts"
    },
    "./repositories": {
      "types": "./src/repositories/index.ts",
      "default": "./src/repositories/index.ts"
    },
    "./http": {
      "types": "./src/http/index.ts",
      "default": "./src/http/index.ts"
    },
    "./errors": {
      "types": "./src/errors/index.ts",
      "default": "./src/errors/index.ts"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "default": "./src/utils/index.ts"
    },
    "./validation": {
      "types": "./src/validation/index.ts",
      "default": "./src/validation/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    },
    "./next": {
      "types": "./src/next/index.ts",
      "default": "./src/next/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "default": "./src/ui/index.ts"
    },
    "./security": {
      "types": "./src/security/index.ts",
      "default": "./src/security/index.ts"
    },
    "./seo": {
      "types": "./src/seo/index.ts",
      "default": "./src/seo/index.ts"
    },
    "./monitoring": {
      "types": "./src/monitoring/index.ts",
      "default": "./src/monitoring/index.ts"
    },
    "./instrumentation": {
      "types": "./src/instrumentation/index.ts",
      "default": "./src/instrumentation/index.ts"
    },
    "./style/*": {
      "types": "./src/style/*/index.ts",
      "default": "./src/style/*/index.ts"
    },
    "./providers/db-firebase": {
      "types": "./src/providers/db-firebase/index.ts",
      "browser": "./src/providers/db-firebase/browser-stub.ts",
      "default": "./src/providers/db-firebase/index.ts"
    },
    "./providers/auth-firebase": {
      "types": "./src/providers/auth-firebase/index.ts",
      "browser": "./src/providers/auth-firebase/browser-stub.ts",
      "default": "./src/providers/auth-firebase/index.ts"
    },
    "./providers/*": {
      "types": "./src/providers/*/index.ts",
      "default": "./src/providers/*/index.ts"
    },
    "./providers/storage-firebase/client": {
      "types": "./src/providers/storage-firebase/client.ts",
      "default": "./src/providers/storage-firebase/client.ts"
    },
    "./features/*": {
      "types": "./src/features/*/index.ts",
      "default": "./src/features/*/index.ts"
    },
    "./features/*/server": {
      "types": "./src/features/*/server.ts",
      "default": "./src/features/*/server.ts"
    },
    "./cli": {
      "types": "./src/cli/index.ts",
      "default": "./src/cli/index.ts"
    },
    "./seed": {
      "types": "./src/seed/index.ts",
      "default": "./src/seed/index.ts"
    },
    "./features/*/schemas": {
      "types": "./src/features/*/schemas/index.ts",
      "default": "./src/features/*/schemas/index.ts"
    },
    "./values": {
      "types": "./src/values/index.ts",
      "default": "./src/values/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "index:generate": "node scripts/get-index.js",
    "typecheck": "tsc --noEmit",
    "watch": "tsc --noEmit --watch --preserveWatchOutput",
    "lint": "eslint src"
  },
  "dependencies": {
    "@mohasinac/sievejs": "^1.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "firebase-admin": ">=12.0.0",
    "next": ">=14",
    "next-intl": ">=3",
    "razorpay": ">=2.9.0",
    "react": ">=18",
    "react-dom": ">=18",
    "recharts": "^3.8.1",
    "resend": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "firebase-admin": {
      "optional": true
    },
    "resend": {
      "optional": true
    },
    "razorpay": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "eslint": "^9.37.0",
    "firebase": "^11.6.0",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^1.7.0",
    "next": "^15.0.0",
    "next-intl": "^4.9.1",
    "razorpay": "^2.9.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.10.0",
    "typescript": "^5.9.3"
  }
}
