{
  "name": "@mohasinac/appkit",
  "version": "2.3.1",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "import": "./dist/providers.js"
    },
    "./styles": "./dist/styles.css",
    "./tokens": "./dist/tokens/tokens.css",
    "./messages/*": "./dist/features/*/messages/en.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "watch": "tsc -p tsconfig.build.json --watch"
  },
  "dependencies": {
    "@mohasinac/sievejs": "^1.0.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "firebase-admin": "^10.3.0",
    "next": ">=14",
    "next-intl": ">=3",
    "razorpay": ">=2.9.0",
    "react": ">=18",
    "react-dom": ">=18",
    "recharts": "^3.8.1",
    "resend": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "firebase-admin": {
      "optional": true
    },
    "resend": {
      "optional": true
    },
    "razorpay": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "eslint": "^9.37.0",
    "firebase": "^11.6.0",
    "firebase-admin": "^10.3.0",
    "lucide-react": "^1.7.0",
    "next": "^15.0.0",
    "next-intl": "^4.9.1",
    "razorpay": "^2.9.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.10.0",
    "typescript": "^5.9.3"
  }
}
